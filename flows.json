    {
        "id": "0c7a32124b4c4020",
        "type": "function",
        "z": "01fbb31d1160f865",
        "name": "Calcular disponibilidad",
        "func": "//Recibimos los datos\nlet sensores = msg.payload;\n\n//Nuevas variables\nlet totalPlazas = 10;\nlet plazasOcupadas = 0;\n\n//Conteo de ocupados\nfor (let plaza in sensores) {\n    if (sensores[plaza] === true) {\n        plazasOcupadas++;\n    }\n}\n\n//Conteo de libres\nlet plazasLibres = totalPlazas - plazasOcupadas;\n\nmsg.payload = {\n    estadoSensores: sensores, \n    resumen: {\n        total: totalPlazas,\n        ocupadas: plazasOcupadas,\n        libres: plazasLibres\n    }\n};\n\nreturn msg;",
